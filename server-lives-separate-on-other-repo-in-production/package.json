{
  "name": "kort-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "prisma migrate deploy && node dist/index.js",
    "start:docker": "prisma migrate deploy && npm run db:seed && node dist/index.js",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:report": "tsx scripts/db-report.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/sensible": "^6.0.0",
    "@prisma/client": "^6.4.0",
    "@types/papaparse": "^5.5.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.0",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.1.6",
    "papaparse": "^5.5.3",
    "prisma": "^6.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
