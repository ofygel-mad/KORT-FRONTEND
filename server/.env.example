# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kort?schema=public"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Server
PORT=8000
HOST="0.0.0.0"
CORS_ORIGIN="http://localhost:5173"

# Seed (used by prisma/seed.ts)
SEED_ADMIN_EMAIL="admin@kort.local"
SEED_ADMIN_PASSWORD="demo1234"

# Service console (dev only — disabled in production)
# Password required to activate god-mode via Shift+` console
CONSOLE_SERVICE_PASSWORD="your-strong-service-password"
